{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "dailyCaloriesGoal": { "type": "number" },
        "dailyProteinGoal": { "type": "number" },
        "credits": { "type": "number" },
        "workoutPlan": { "type": "string", "description": "JSON stringified workout plan" }
      }
    },
    "Meal": {
      "title": "Meal",
      "description": "A meal logged by the user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "time": { "type": "string" },
        "imageUrl": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "calories", "protein", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile data"
    },
    "/users/{userId}/meals/{mealId}": {
      "schema": { "$ref": "#/entities/Meal" },
      "description": "Meals logged by the user"
    }
  }
}
